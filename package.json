{
  "name": "@opusaether/pine-transpiler",
  "version": "0.2.0",
  "description": "Transpile Pine Script v5/v6 to executable JavaScript. Zero dependencies.",
  "author": "Opus Aether AI",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pine-transpiler": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "start": "bun ./dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "clean": "rm -rf dist",
    "test": "bun test tests/",
    "test:coverage": "bun test --coverage tests/",
    "corpus": "bun scripts/corpus/report.ts",
    "corpus:strict": "bun scripts/corpus/strict-audit.ts",
    "corpus:matrix": "bun scripts/corpus/indicator-matrix.ts",
    "corpus:snap": "UPDATE_SNAPSHOTS=1 bun test tests/corpus/",
    "prepare": "vite build"
  },
  "keywords": [
    "pine-script",
    "tradingview",
    "pinejs",
    "transpiler",
    "compiler",
    "technical-analysis",
    "indicators",
    "charting",
    "trading",
    "finance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Opus-Aether-AI/pine-transpiler"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  }
}

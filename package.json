{
  "name": "@opus-aether-ai/pine-transpiler",
  "version": "0.4.11",
  "description": "Transpile Pine Script v5/v6 to executable JavaScript. Zero dependencies.",
  "author": "Opus Aether AI",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pine-transpiler": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness/index.d.ts",
      "import": "./dist/test-harness/index.js",
      "require": "./dist/test-harness/index.cjs"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE",
    "DISCLAIMER.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:drawing-bundle": "bun scripts/build-drawing-bundle.ts",
    "dev": "vite build --watch",
    "start": "bun ./dist/cli/index.js",
    "docs:surface": "bun scripts/gen-supported-surface.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "clean": "rm -rf dist",
    "test": "bun test tests/",
    "test:harness": "bun test tests/integration/runtime-descriptor-contract.test.ts tests/integration/runtime-reducer-survival.test.ts",
    "test:coverage": "bun scripts/check-coverage.ts",
    "corpus": "bun scripts/corpus/report.ts",
    "corpus:strict": "bun scripts/corpus/strict-audit.ts",
    "scan": "bun scripts/scan-script.ts",
    "corpus:matrix": "bun scripts/corpus/indicator-matrix.ts",
    "corpus:critical": "bun scripts/corpus/critical-matrix.ts",
    "corpus:top100": "bun scripts/corpus/top100-matrix.ts",
    "corpus:top200": "bun scripts/corpus/top200-matrix.ts",
    "corpus:forex-xau": "bun scripts/corpus/forex-xau-matrix.ts",
    "corpus:differential": "bun scripts/corpus/strict-audit.ts",
    "corpus:gate": "bun scripts/corpus/gate.ts",
    "chart:safety": "bun scripts/corpus/chart-safety.ts",
    "corpus:visual": "bun scripts/corpus/visual-parity.ts",
    "visual:harness": "bun tests/visual-harness/run.ts",
    "visual:harness:gate": "bun scripts/visual-harness-gate.ts",
    "visual:harness:update": "bun tests/visual-harness/run.ts --update-snapshots",
    "corpus:snap": "UPDATE_SNAPSHOTS=1 bun test tests/corpus/ && UPDATE_VISUAL_SNAPSHOTS=1 bun run corpus:visual",
    "prepare": "vite build",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run build",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org",
    "publish:gh": "npm publish --registry=https://npm.pkg.github.com --ignore-scripts",
    "release": "bun run publish:npm && bun run publish:gh"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pine-script",
    "chart-host",
    "pinejs",
    "transpiler",
    "compiler",
    "technical-analysis",
    "indicators",
    "charting",
    "trading",
    "finance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Opus-Aether-AI/pine-transpiler"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}

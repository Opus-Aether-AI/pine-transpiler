//@version=5
indicator("LuxAlgo Nadaraya-Watson Envelope", overlay=true)

len = input.int(30, "Length", minval=2)
mult = input.float(2.0, "Multiplier", minval=0.1)

nw = ta.ema(ta.ema(close, len), math.max(2, len / 2))
vol = ta.stdev(close, len)
upper = nw + vol * mult
lower = nw - vol * mult

pU = plot(upper, "Upper", color=color.new(color.red, 0))
pL = plot(lower, "Lower", color=color.new(color.green, 0))
plot(nw, "NW", color=color.new(color.blue, 0))
fill(pU, pL, color=color.new(color.blue, 90))

//@version=5
// Synthetic proxy fixture — not a copy of any author-published script.
indicator("Squeeze Momentum", overlay=false)

length = input.int(20, "Length", minval=1)
bbMult = input.float(2.0, "BB Mult", minval=0.1)
kcMult = input.float(1.5, "KC Mult", minval=0.1)

basis = ta.sma(close, length)
dev = bbMult * ta.stdev(close, length)
upperBB = basis + dev
lowerBB = basis - dev

rangeMA = ta.sma(ta.tr(true), length)
upperKC = basis + rangeMA * kcMult
lowerKC = basis - rangeMA * kcMult

sqzOn = lowerBB > lowerKC and upperBB < upperKC
momentum = close - ta.sma(close, length)

plot(momentum, "Momentum", color=sqzOn ? color.red : color.lime, style=plot.style_histogram)
plot(0, "Zero", color=color.gray)

//@version=5
// Synthetic proxy fixture — not a copy of any author-published script.
indicator("GEX and OI Levels", overlay=true)

base = ta.sma(close, 20)
volNorm = ta.sma(volume, 20)
gex = base + ta.ema((close - base) * (volume / math.max(volNorm, 1)), 5)
oi = base - ta.ema((close - base) * 0.5, 8)

plot(gex, "GEX", color=color.aqua)
plot(oi, "OI", color=color.orange)
plot(base, "Base", color=color.gray)

//@version=5
indicator("LuxAlgo Smart Money Concepts", overlay=true)

bullBos = close > ta.highest(high[1], 20)
bearBos = close < ta.lowest(low[1], 20)
bullFvg = low > high[2]
bearFvg = high < low[2]

plotshape(bullBos, title="Bull BOS", style=shape.labelup, location=location.belowbar, color=color.lime, text="BOS")
plotshape(bearBos, title="Bear BOS", style=shape.labeldown, location=location.abovebar, color=color.red, text="BOS")
plotshape(bullFvg or bearFvg, title="FVG", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)

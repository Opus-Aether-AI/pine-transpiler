//@version=5
indicator("Liquidity Heatmap and GPT-based Price Level Detector [AlgoAlpha]", overlay=true)

len = input.int(50, "Window", minval=10)
hi = ta.highest(high, len)
lo = ta.lowest(low, len)
mid = (hi + lo) / 2.0

liqTop = hi - (hi - lo) * 0.2
liqBot = lo + (hi - lo) * 0.2
heat = math.abs(close - mid)

plot(liqTop, "Upper Liquidity", color=color.new(color.red, 0))
plot(liqBot, "Lower Liquidity", color=color.new(color.green, 0))
plot(mid, "AI Mid", color=color.new(color.blue, 0))
plot(heat, "Heat", color=color.new(color.orange, 80), display=display.none)

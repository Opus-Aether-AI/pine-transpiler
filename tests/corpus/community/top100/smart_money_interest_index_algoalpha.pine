//@version=5
indicator("Smart Money Interest Index [AlgoAlpha]", overlay=false)

len = input.int(20, "Length", minval=1)
range = math.max(high - low, syminfo.mintick)
smartFlow = ((close - open) / range) * volume
noiseFlow = math.abs(close - close[1]) * volume

smart = ta.ema(smartFlow, len)
noise = ta.ema(noiseFlow, len)
index = smart - noise
signal = ta.ema(index, math.max(2, len / 2))

plot(index, "SMI", color=color.aqua)
plot(signal, "Signal", color=color.orange)
plot(index - signal, "Delta", color=color.new(color.blue, 70), style=plot.style_histogram)

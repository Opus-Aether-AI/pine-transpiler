//@version=5
indicator("Array Stats", overlay=false)
length = input.int(20, "Length")
arr = array.new<float>(0)
for i = 0 to length - 1
    array.push(arr, close[i])
plot(array.sum(arr) / array.size(arr), "Avg", color=color.blue)
plot(array.max(arr), "Max", color=color.green)
plot(array.min(arr), "Min", color=color.red)
